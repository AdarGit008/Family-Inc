; Weekly briefing — Sat 21:00, queues kind=briefing (budget-exempt, SPEC §7.2).
[Unit]
Description=Family inc. weekly briefing (Sat 21:00)
OnFailure=family-fail-flag@%n.service

[Service]
Type=oneshot
User=familyinc
WorkingDirectory=/opt/family-inc
EnvironmentFile=-/etc/family-inc/env
ExecStart=/usr/local/bin/uv run --no-sync python automation/weekly_briefing.py --send
NoNewPrivileges=true
