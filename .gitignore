# OS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Node
node_modules/

# WhatsApp bridge — credentials & runtime state (NEVER commit)
automation/bridge/state/
auth_state/
auth_info*/
recipients.json
*.log

# Dashboard — real config carries Sheet ID, OAuth client id, account emails
# (config.example.js is the committed template, ENGINEERING §3; on Pages it is
# generated from Actions secrets by .github/workflows/pages.yml)
dashboard/config.js

# Secrets / env
.env
.env.*
*.pem
*.key
credentials.json
token.json
*credential*
*secret*
# M6 read-only bank logins live in /etc (D-049); never a repo copy (inline
# comments don't work in .gitignore — keep the pattern on its own line)
bank_creds.json
*_creds.json

# Runtime output — generated, not source (re-applies Hermes 556f445)
Briefings/
logs/*
!logs/.gitkeep

# Seeds — personal values (names, schedules) stay on the machines that need
# them; the repo is public-portfolio-safe by construction (CLAUDE.md guardrail).
# redact.txt = D-030 rewrite rules; it carries the strings it removes, so it
# lives only on PO machines + backups (deploy/publish.sh refuses to run without it)
seeds/*.csv
seeds/redact.txt

# Archive docs carrying personal data (kid names, health backlog, money
# baseline) — untracked at M3 session 1 (D-027 follow-up to D-024; files stay
# on PO machines + backups, the rest of Archive/ remains the public paper trail)
Archive/00_Runbook.md
Archive/02_Kickoff_Output_2026-05-30.md
Archive/05_Dashboard_Design.md
Archive/06_Lift_Recommendations_2026-05-30.md
Archive/07_Maccabi_Passport_Forwarders.md
Archive/07_WhatsApp_Group_Summarizer_Spec.md
Archive/CLAUDE_2026-06-04.md
Archive/Progress/index.html

# Local caches (the summarizer staging CSVs were deleted at the M2 gspread port;
# automation/data/ stays ignored so stale copies on dev machines never get tracked)
automation/cache/
automation/data/

# stray pytest custom-cache dirs (sandbox runs)
pytest-cache-files-*/
